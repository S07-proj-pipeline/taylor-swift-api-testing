# =========================================================
# EXEMPLO DE VARIÁVEIS DE AMBIENTE
# IMPORTANTE: Copia este ficheiro, renomeia a cópia para ".env"
# e preenche com os teus dados reais antes de subir os contentores.
# =========================================================

# Configurações Gerais da Pipeline
NOME_PIPELINE=taylor-swift-api-testing-pipeline

# Configurações de Notificação
EMAILS_DESTINO=teste1@inatel.br, teste2@inatel.br # Destinatários separados por vírgula
MODO_ENVIO=local # Opções suportadas: 'local' (para usar o MailHog) ou 'real'

# Credenciais do Provedor de E-mail (Obrigatório apenas se MODO_ENVIO=real)
# NÃO colocar a senha real aqui! Preencher apenas no ficheiro .env final.
REMETENTE_REAL=seu_email_aqui@gmail.com
SENHA_REAL=sua_senha_de_aplicativo_aqui