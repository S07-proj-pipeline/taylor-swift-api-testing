    {
      "name": "Buscar album inexistente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status deve ser 404 Not Found\", function () {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve ser JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta de erro não é um array\", () => {\r",
              "    pm.expect(pm.response.json()).to.not.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta contém uma mensagem de erro amigável\", () => {\r",
              "    pm.expect(pm.response.json()).to.have.any.keys(\"message\", \"error\");\r",
              "    pm.expect(pm.response.json().error).to.include(\"does not exist\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
