    {
      "name": "Buscar todos os álbuns",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('T101 - Status deve ser 200 OK', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('T102 - Resposta deve ser JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"T103 - Verifica se a resposta é um array\", () => {\r",
              "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"T104 - Verifica se a resposta contém os 12 álbums\", () => {\r",
              "    pm.expect(Object.keys(pm.response.json()).length).to.eql(12);\r",
              "});\r",
              "\r",
              "pm.test(\"T105 - Verifica se todos os álbums têm título\", () => {\r",
              "    pm.response.json().forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"title\");\r",
              "    })\r",
              "})\r",
              "\r",
              "pm.test(\"T106 - Verifica se a resposta contém o álbum Midnights\", () => {\r",
              "    pm.expect(pm.response.text()).to.include(\"Midnights\");\r",
              "})\r",
              "\r",
              "pm.test(\"T107 - Verifica se a data de lançamento do álbum Midnights é 21/10/2022\", () => {\r",
              "    const response = pm.response.json();\r",
              "    const correctReleaseDate = new Date(\"2022-10-21\");\r",
              "    const midnightsResponseReleaseDate = new Date(response[9].release_date);\r",
              "    pm.expect(midnightsResponseReleaseDate).to.include(correctReleaseDate);\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
