		{
			"name": "Buscar músicas presentes no The Eras Tour",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status deve ser 200 OK\", function () {",
							"    pm.response.to.have.status(200)",
							"})",
							"",
							"pm.test(\"Garante que o setlist da The Eras Tour possui ID e Album\", function () {",
							"    const df = pm.response.json()",
							"",
							"    const setlistErasTour = [",
							"        \"Miss Americana & The Heartbreak Prince\",",
							"        \"Cruel Summer\",",
							"        \"The Man\",",
							"        \"You Need To Calm Down\",",
							"        \"Lover\",",
							"        \"The Archer\",",
							"        \"Fearless\",",
							"        \"You Belong With Me\",",
							"        \"Love Story\",",
							"        \"willow\",",
							"        \"marjorie\",",
							"        \"champagne problems\",",
							"        \"tolerate it\",",
							"        \"...Ready For It?\",",
							"        \"Delicate\",",
							"        \"Don\\\\'t Blame Me\",",
							"        \"Look What You Made Me Do\",",
							"        \"Enchanted\",",
							"        \"Long Live\",",
							"        \"22 (Taylor’s version)\",",
							"        \"We Are Never Ever Getting Back Together (Taylor’s version)\",",
							"        \"I Knew You Were Trouble (Taylor’s version)\",",
							"        \"All Too Well (Taylor’s version)\",",
							"        \"the 1\",",
							"        \"betty\",",
							"        \"the last great american dynasty\",",
							"        \"august\",",
							"        \"illicit affairs\",",
							"        \"my tears ricochet\",",
							"        \"cardigan\",",
							"        \"Style\",",
							"        \"Blank Space\",",
							"        \"Shake It Off\",",
							"        \"Wildest Dreams\",",
							"        \"Bad Blood\",",
							"        \"Lavender Haze\",",
							"        \"Anti-Hero\",",
							"        \"Midnight Rain\",",
							"        \"Vigilante Shit\",",
							"        \"Bejeweled\",",
							"        \"Mastermind\",",
							"        \"Karma\",",
							"        \"‘tis the damn season\",",
							"        \"invisible string\"",
							"    ]",
							"",
							"    const musicasFaltantes = []",
							"",
							"    setlistErasTour.forEach(function(hit) {",
							"        const musicaEncontrada = df.find(function(musica) {",
							"            return musica.title.trim().toLowerCase() === hit.trim().toLowerCase()",
							"        })",
							"",
							"        if (musicaEncontrada === undefined) {",
							"            console.log(\"Musica que deu problema e nao foi encontrada \" + hit)",
							"            musicasFaltantes.push(hit)",
							"        } else {",
							"            pm.expect(musicaEncontrada).to.have.property(\"title\")",
							"            pm.expect(musicaEncontrada).to.have.property(\"song_id\")",
							"            pm.expect(musicaEncontrada).to.have.property(\"album_id\")",
							"        }",
							"    })",
							"",
							"    pm.expect(musicasFaltantes.length, \"Musicas faltando \" + musicasFaltantes.join(\", \")).to.eql(0)",
							"})"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
