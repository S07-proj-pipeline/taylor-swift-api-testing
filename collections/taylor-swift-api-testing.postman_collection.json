  "item": [
    {
      "name": "Buscar todos os albums",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status deve ser 200 OK', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Resposta deve ser JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta é um array\", () => {\r",
              "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta contém os 12 álbums\", () => {\r",
              "    pm.expect(Object.keys(pm.response.json()).length).to.eql(12);\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se todos os álbums têm título\", () => {\r",
              "    pm.response.json().forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"title\");\r",
              "    })\r",
              "})\r",
              "\r",
              "pm.test(\"Verifica se a resposta contém o álbum Midnights\", () => {\r",
              "    pm.expect(pm.response.text()).to.include(\"Midnights\");\r",
              "})\r",
              "\r",
              "pm.test(\"Verifica se a data de lançamento do álbum Midnights é 21/10/2022\", () => {\r",
              "    const response = pm.response.json();\r",
              "    const correctReleaseDate = new Date(\"2022-10-21\");\r",
              "    const midnightsResponseReleaseDate = new Date(response[9].release_date);\r",
              "    pm.expect(midnightsResponseReleaseDate).to.include(correctReleaseDate);\r",
              "})\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseURL}}/albums",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "albums"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Busca as músicas do álbum Midnights",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status deve ser 200 OK', function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test('Resposta deve ser JSON', function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta é um array\", () => {\r",
              "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se a resposta contém as 22 músicas\", () => {\r",
              "    pm.expect(Object.keys(pm.response.json()).length).to.eql(22);\r",
              "});\r",
              "\r",
              "pm.test(\"Verifica se todas as músicas têm título\", () => {\r",
              "    pm.response.json().forEach(item => {\r",
              "        pm.expect(item).to.have.property(\"title\");\r",
              "    })\r",
              "})\r",
              "\r",
              "pm.test(\"Verifica se a resposta contém a música 'Anti-Hero\", () => {\r",
              "    pm.expect(pm.response.text()).to.include(\"Anti-Hero\");\r",
              "})\r",
              "\r",
              "pm.test(\"Verifica se o id da música 'Anti-Hero' é 157\", () => {\r",
              "    let antiHeroObject;\r",
              "    pm.response.json().forEach(item => {\r",
              "        if(item.title===\"Anti-Hero\"){\r",
              "            antiHeroObject = item;\r",
              "        }\r",
              "    });\r",
              "\r",
              "    pm.expect(antiHeroObject.song_id).to.eql(157);\r",
              "\r",
              "})\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
